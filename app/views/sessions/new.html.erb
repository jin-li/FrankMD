<!DOCTYPE html>
<html>
  <head>
    <title>Sign In - FrankMD</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
  </head>
  <body class="bg-gray-50 dark:bg-gray-900">
    <div class="min-h-screen flex items-center justify-center px-4">
      <div class="max-w-md w-full space-y-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">FrankMD</h1>
          <p class="text-gray-600 dark:text-gray-400">Markdown Editor</p>
        </div>

        <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg p-8">
          <% if flash[:alert] %>
            <div class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-200 rounded-md">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <% if flash[:notice] %>
            <div class="mb-4 p-4 bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 rounded-md">
              <%= flash[:notice] %>
            </div>
          <% end %>

          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6 text-center">
            Sign In
          </h2>

          <div class="space-y-4">
            <%= button_to "Sign in with OIDC Provider", 
                          "/auth/openid_connect", 
                          method: :post,
                          class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors",
                          data: { turbo: false } %>
          </div>

          <div class="mt-6 text-center text-sm text-gray-600 dark:text-gray-400">
            <p>Sign in with your organization's identity provider</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
